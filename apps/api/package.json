{
  "name": "@library-lending/api",
  "version": "0.1.0",
  "private": true,
  "main": "src/serverless.ts",
  "exports": {
    ".": "./src/serverless.ts"
  },
  "scripts": {
    "dev": "nest start --watch",
    "build": "node scripts/run-with-env.js --fallback-url prisma generate && nest build",
    "db:generate": "node scripts/run-with-env.js --fallback-url prisma generate",
    "db:migrate:deploy": "node scripts/run-with-env.js prisma migrate deploy",
    "db:migrate:dev": "node scripts/run-with-env.js prisma migrate dev",
    "db:seed": "node scripts/run-with-env.js prisma db seed",
    "db:studio": "node scripts/run-with-env.js prisma studio",
    "verify:cases": "node scripts/run-with-env.js node scripts/verify-cases.js",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24",
    "@nestjs/platform-express": "11.1.24",
    "@prisma/client": "6.19.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "serverless-http": "4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "prisma": "6.19.3",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}
